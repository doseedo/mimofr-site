$(document).ready(function() {
    console.log(new Date(), 'Webflow footer, $(document).ready');
    if (typeof kakaoPixel !== 'undefined') {
        console.log('footer kakaoPixel:', kakaoPixel);
    }

    $('[data-analytics]').on('click', function(e) {
        var properties
        var event = $(this).attr('data-analytics');
        var kakaoEvent = $(this).attr('kakao-event');
        $.each(this.attributes, function(_, attribute) {
            if (attribute.name.startsWith('data-property-')) {
                if (!properties) properties = {}
                var property = attribute.name.split('data-property-')[1]
                properties[property] = attribute.value
            }
        })
        analytics.track(event, properties);
        if (typeof kakaoPixel === 'function' && kakaoEvent) {
            var kakaoPixelId = isProd ? '208597432233381347' : '8239936643395699044';
            kakaoPixel(kakaoPixelId)[kakaoEvent]();
        }
    })
});
</script>


