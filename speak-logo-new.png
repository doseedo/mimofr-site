<script>
    // Global environment flag - used across all script blocks
    const isProd = window.location.hostname.includes("speak.com");

    (function() {
        const uuid = isProd ? "67379c16-3d09-11ee-a59a-73c36c75b2d1" : "dc1492e8-571a-11ee-b1f5-db889fac3eed";
        const enzuzoScript = document.createElement("script");
        enzuzoScript.src = `https://app.enzuzo.com/apps/enzuzo/static/js/__enzuzo-cookiebar.js?uuid=${uuid}`;
        enzuzoScript.async = true;
        document.head.appendChild(enzuzoScript);
    })();

    function getCookie(name) {
        const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
        return match ? match[2] : null;
    }

    // Consent management IIFE - keeps internal state private
    // (matches analytics-consent.ts in speak-app)
    (function() {
        const ENZUZO_BANNER_ID = 'ez-cookie-notification';
        const ENZUZO_SCRIPT_URL_PATTERN = 'app.enzuzo.com';
        const CONSENT_CONFIG = {
            loadedTimeoutMs: 5 * 1000,
            pollIntervalMs: 100
        };
        const COOKIE_MAPPING = {
            advertising: 'cookies-marketing',
            analytics: 'cookies-analytics'
        };

        let gtagDefaultsSet = false;
        let bannerWasDetected = false;
        let scriptLoaded = false;
        let scriptErrored = false;
        let outageHandled = false;

        // In-memory consent state (matches analytics-consent.ts)
        // undefined = user hasn't decided, true = consented, false = declined
        const categoryPreferences = {
            advertising: undefined,
            analytics: undefined
        };

        function getConsentFromCookie(category) {
            const value = getCookie(COOKIE_MAPPING[category]);
            if (value === null) return undefined;
            return value === 'true';
        }

        // Syncs from cookies to catch updates from other tabs
        function getConsentPreferences() {
            const advertisingFromCookie = getConsentFromCookie('advertising');
            const analyticsFromCookie = getConsentFromCookie('analytics');

            if (advertisingFromCookie !== undefined) {
                categoryPreferences.advertising = advertisingFromCookie;
            }
            if (analyticsFromCookie !== undefined) {
                categoryPreferences.analytics = analyticsFromCookie;
            }

            return categoryPreferences;
        }

        function updateConsentPreferences(updates) {
            for (const category in updates) {
                categoryPreferences[category] = updates[category];
            }
            propagateConsent();
        }

        function propagateConsent() {
            window.dataLayer = window.dataLayer || [];
            const gtagConsentValue = (v) => v === true ? 'granted' : 'denied';
            const prefs = getConsentPreferences();
            window.dataLayer.push([
                'consent',
                gtagDefaultsSet ? 'update' : 'default',
                {
                    ad_storage: gtagConsentValue(prefs.advertising),
                    ad_user_data: gtagConsentValue(prefs.advertising),
                    ad_personalization: gtagConsentValue(prefs.advertising),
                    analytics_storage: gtagConsentValue(prefs.analytics),
                },
            ]);
            gtagDefaultsSet = true;
        }

        function hasUserDecidedConsent() {
            const prefs = getConsentPreferences();
            return prefs.advertising !== undefined && prefs.analytics !== undefined;
        }

        function checkForBanner() {
            if (!bannerWasDetected) {
                const banner = document.getElementById(ENZUZO_BANNER_ID);
                if (banner) {
                    bannerWasDetected = true;
                }
            }
            return bannerWasDetected;
        }

        function isEnzuzoScriptInDom() {
            return !!document.querySelector('script[src*="' + ENZUZO_SCRIPT_URL_PATTERN + '"]');
        }

        function handleOutage(reason) {
            if (outageHandled) return;
            outageHandled = true;
            console.warn('[Consent] Enzuzo outage detected:', reason);
            // Grant consent as fallback to prevent losing events
            updateConsentPreferences({ advertising: true, analytics: true });
        }

        function startOutageDetection() {
            const startTime = Date.now();

            const check = () => {
                checkForBanner();
                if (hasUserDecidedConsent()) return;

                const elapsed = Date.now() - startTime;
                if (elapsed > CONSENT_CONFIG.loadedTimeoutMs) {
                    const isOutage = scriptErrored || !isEnzuzoScriptInDom() || (!scriptLoaded && !bannerWasDetected);
                    if (isOutage) {
                        if (scriptErrored) {
                            handleOutage('script_error');
                        } else if (!isEnzuzoScriptInDom()) {
                            handleOutage('script_not_found');
                        } else {
                            handleOutage('script_timeout');
                        }
                    }
                    return;
                }

                setTimeout(check, CONSENT_CONFIG.pollIntervalMs);
            };

            check();
        }

        // Expose getConsentPreferences for Segment middleware
        window.getConsentPreferences = getConsentPreferences;

        // Expose handlers to window for Enzuzo (see analytics-consent.md)
        window.handleOptIn = function(category) {
            updateConsentPreferences({ [category]: true });
            if (window.analytics) {
                window.analytics.track('Analytics Opt In', { category: category });
            }
        };

        window.handleOptOut = function(category) {
            updateConsentPreferences({ [category]: false });
            if (window.analytics) {
                window.analytics.track('Analytics Opt Out', { category: category });
            }
        };

        window.handleConsentScriptLoaded = function() {
            scriptLoaded = true;
        };

        window.handleConsentScriptError = function() {
            scriptErrored = true;
            handleOutage('script_error');
        };

        // Initialize on load
        propagateConsent();
        startOutageDetection();
    })();

    // Amplitude Session Replay IIFE - keeps internal state private
    // (matches amplitudeReplay.ts in speak-app)
    (function() {
        var AMPLITUDE_SESSION_STORAGE_KEY = 'replaySessionId';
        var PROD_SAMPLE_RATE = 0.01;
        var AMPLITUDE_REPLAY_KEY = isProd
            ? 'eb7d514fffd697a0aa3fd406f449b163'
            : '3977b9651c7d952f9eb1a5308ec3cb03';

        var sessionReplayModule = null;
        var initStarted = false; // guard against duplicate init calls
        var fallbackSessionId = null; // stable fallback when sessionStorage is unavailable

        function getStoredSessionId() {
            try {
                var id = parseInt(sessionStorage.getItem(AMPLITUDE_SESSION_STORAGE_KEY) || '0');
                if (!id) {
                    // From Amplitude docs: The value must be in milliseconds since epoch (Unix Timestamp).
                    id = Date.now();
                    sessionStorage.setItem(AMPLITUDE_SESSION_STORAGE_KEY, id.toString());
                }
                return id;
            } catch (e) {
                // sessionStorage blocked — return a stable value for this page load
                if (!fallbackSessionId) {
                    fallbackSessionId = Date.now();
                }
                return fallbackSessionId;
            }
        }

        // FNV-1a hash for deterministic, well-distributed sampling by session ID.
        function fnv1aHash(str) {
            var hash = 0x811c9dc5;
            for (var i = 0; i < str.length; i++) {
                hash ^= str.charCodeAt(i);
                hash = Math.imul(hash, 0x01000193);
            }
            return hash >>> 0;
        }

        function shouldSampleReplay(sessionId, rate) {
            return (fnv1aHash(sessionId) % 10000) / 10000 < rate;
        }

        function getSessionReplayProperties() {
            if (!sessionReplayModule) {
                return undefined;
            }
            return sessionReplayModule.getSessionReplayProperties();
        }

        function initSessionReplay(deviceId) {
            if (initStarted) {
                return;
            }
            if (!isProd) {
                // Comment this line to enable session replay in dev
                return;
            }
            if (!AMPLITUDE_REPLAY_KEY || !deviceId) {
                return;
            }
            var sessionId = getStoredSessionId();
            var sampleRate = isProd ? PROD_SAMPLE_RATE : 1;
            if (!shouldSampleReplay(sessionId.toString(), sampleRate)) {
                return;
            }

            initStarted = true;
            var script = document.createElement('script');
            script.src = 'https://cdn.amplitude.com/libs/session-replay-browser-1.25.0-min.js.gz';
            script.async = true;
            script.onload = function() {
                var SR = window.sessionReplay && window.sessionReplay.SessionReplay;
                if (typeof SR !== 'function') {
                    console.warn('[SessionReplay] SDK loaded but SessionReplay class not found');
                    return;
                }
                sessionReplayModule = new SR();
                var result = sessionReplayModule.init(AMPLITUDE_REPLAY_KEY, {
                    deviceId: deviceId,
                    sessionId: sessionId,
                    sampleRate: 1,
                    logLevel: 4,
                });
                if (result && result.promise) {
                    result.promise.catch(function(err) {
                        console.warn('[SessionReplay] init failed:', err);
                    });
                }
            };
            script.onerror = function() {
                console.warn('[SessionReplay] Failed to load SDK');
            };
            document.head.appendChild(script);
        }

        // Expose to window for use in Segment middleware and initAnalytics
        window.getSessionReplayProperties = getSessionReplayProperties;
        window.getStoredSessionId = getStoredSessionId;
        window.initSessionReplay = initSessionReplay;
    })();

    function addSegmentSourceMiddleware(analytics) {
        // Keep middleware isolated from the snippet so upgrades are a one-line change.
        analytics.addSourceMiddleware(({ payload, next }) => {
            const { obj } = payload;

            obj.properties = obj.properties || {};
            const fbc = getCookie('_fbc');
            if (fbc) obj.properties.fbc = fbc;
            const fbp = getCookie('_fbp');
            if (fbp) obj.properties.fbp = fbp;

            // Add Amplitude session replay properties
            const sessionReplayProperties = window.getSessionReplayProperties();
            if (sessionReplayProperties) {
                Object.assign(obj.properties, sessionReplayProperties);
            }

            // Add Amplitude session_id for session stitching
            try {
                obj.integrations = Object.assign({}, obj.integrations, {
                    Amplitude: {
                        session_id: window.getStoredSessionId(),
                    },
                });
            } catch (e) {
                // Silently ignore sessionStorage errors
            }

            const prefs = window.getConsentPreferences();
            obj.context = obj.context || {};
            obj.context.consent = {
                categoryPreferences: {
                    advertising: prefs.advertising === true,
                    analytics: prefs.analytics === true,
                    functional: true
                }
            };

            next(payload);
        });
    }

    // FB Pixel initialization (matches analytics.ts in speak-app)
    function initFbPixel() {
        // Trigger FB Pixel to load as a client-side Segment destination
        // https://www.twilio.com/docs/segment/connections/destinations/catalog/facebook-pixel
        analytics.track('Init FB Pixel');

        // Wait for the _fbp cookie (max 10s).
        const fbPixelTimeoutMs = 10 * 1000;
        const pollIntervalMs = 100;
        const maxAttempts = fbPixelTimeoutMs / pollIntervalMs;
        let attempt = 0;
        const checkFbp = () => {
            if (getCookie('_fbp')) {
                // Guarantee at least 1 event has fbc/fbp attached via middleware
                analytics.track('FB Pixel Ready');
                return;
            }
            if (attempt > maxAttempts) {
                return;
            }
            attempt++;
            setTimeout(checkFbp, pollIntervalMs);
        };
        checkFbp();
    }

    function installSegmentSnippet(segmentId) {
        // START of Segment Analytics.js v5.2.1 snippet.
        // https://www.twilio.com/docs/segment/connections/sources/catalog/libraries/website/javascript/quickstart

        // define the key where the global analytics object will be accessible
        // customers can safely set this to be something else if need be
        var globalAnalyticsKey = "analytics"

        // Create a queue, but don't obliterate an existing one!
        var analytics = window[globalAnalyticsKey] = window[globalAnalyticsKey] || [];

        // If the real analytics.js is already on the page return.
        if (analytics.initialize) return;

        // If the snippet was invoked already show an error.
        if (analytics.invoked) {
            if (window.console && console.error) {
                console.error("Segment snippet included twice.");
            }
            return;
        }

        // Invoked flag, to make sure the snippet
        // is never invoked twice.
        analytics.invoked = true;

        // A list of the methods in Analytics.js to stub.
        analytics.methods = [
            "trackSubmit",
            "trackClick",
            "trackLink",
            "trackForm",
            "pageview",
            "identify",
            "reset",
            "group",
            "track",
            "ready",
            "alias",
            "debug",
            "page",
            "screen",
            "once",
            "off",
            "on",
            "addSourceMiddleware",
            "addIntegrationMiddleware",
            "setAnonymousId",
            "addDestinationMiddleware",
            "register"
        ];

        // Define a factory to create stubs. These are placeholders
        // for methods in Analytics.js so that you never have to wait
        // for it to load to actually record data. The `method` is
        // stored as the first argument, so we can replay the data.
        analytics.factory = function(e) {
            return function() {
                if (window[globalAnalyticsKey].initialized) {
                    // Sometimes users assigned analytics to a variable before analytics is done loading, resulting in a stale reference.
                    // If so, proxy any calls to the 'real' analytics instance.
                    return window[globalAnalyticsKey][e].apply(window[globalAnalyticsKey], arguments);
                }
                var args = Array.prototype.slice.call(arguments);

                // Add buffered page context object so page information is always up-to-date
                if (["track", "screen", "alias", "group", "page", "identify"].indexOf(e) > -1) {
                    var c = document.querySelector("link[rel='canonical']");
                    args.push({
                    __t: "bpc",
                    c: c && c.getAttribute("href") || undefined,
                    p: location.pathname,
                    u: location.href,
                    s: location.search,
                    t: document.title,
                    r: document.referrer
                    });
                }

                args.unshift(e);
                analytics.push(args);
                return analytics;
            };
        };


        // For each of our methods, generate a queueing stub.
        for (var i = 0; i < analytics.methods.length; i++) {
            var key = analytics.methods[i];
            analytics[key] = analytics.factory(key);
        }

        // Define a method to load Analytics.js from our CDN,
        // and that will be sure to only ever load it once.
        analytics.load = function(key, options) {
            // Create an async script element based on your key.
            var t = document.createElement("script");
            t.type = "text/javascript";
            t.async = true;
            t.setAttribute("data-global-segment-analytics-key", globalAnalyticsKey)
            t.src = "https://evs.t.speak.com/analytics.js/v1/" + key + "/analytics.min.js";

            // Insert our script next to the first script element.
            var first = document.getElementsByTagName("script")[0];
            first.parentNode.insertBefore(t, first);
            analytics._loadOptions = options;
        };
        analytics._writeKey = segmentId;
        analytics._cdn = "https://evs.t.speak.com";



        // Add a version to keep track of what's in the wild.
        analytics.SNIPPET_VERSION = "5.2.1";

        // END of the Segment snippet block. load() and page() calls have been moved outside and customized.

        return analytics;
    }

    // Dynamically load both Kakao scripts and initialize after both are ready
    function initKakao(kakaoId, kakaoPixelId) {
        const KAKAO_SDK_URL = 'https://t1.kakaocdn.net/kakao_js_sdk/v1/kakao.min.js';
        const KAKAO_PIXEL_URL = 'https://t1.daumcdn.net/adfit/static/kp.js';

        function loadScript(src) {
            return new Promise((resolve, reject) => {
                const script = document.createElement('script');
                script.src = src;
                script.async = true;
                script.onload = resolve;
                script.onerror = reject;
                document.head.appendChild(script);
            });
        }

        // Load both scripts in parallel, then initialize
        Promise.all([
            loadScript(KAKAO_SDK_URL),
            loadScript(KAKAO_PIXEL_URL)
        ])
        .then(() => {
            // Both scripts loaded - safe to initialize
            if (typeof Kakao !== 'undefined' && !Kakao.isInitialized()) {
                Kakao.init(kakaoId);
                console.log('Kakao SDK initialized');
            }
            if (typeof kakaoPixel === 'function') {
                kakaoPixel(kakaoPixelId).pageView();
                console.log('Kakao Pixel pageView sent');
            }
        })
        .catch((err) => {
            console.warn('Failed to load Kakao scripts:', err);
        });
    }

    function initAnalytics(segmentId, kakaoId, kakaoPixelId) {
        // Intentionally global for backwards compatibility with the rest of the code.
        analytics = installSegmentSnippet(segmentId);

        if (!analytics) {
            return
        }

        // Custom middleware stays outside the snippet so updates are easy.
        addSegmentSourceMiddleware(analytics);

        // Cookie domain configuration.
        // The load/page calls live here so we can pass cookie options.
        const cookieDomain = '.' + document.location.hostname.replace(/^(?:https?:\/\/)?(?:[^\/]+\.)?([^.\/]+\.[^.\/]+).*$/, "$1");
        analytics.load(segmentId, {
            cookie: {
                domain: cookieDomain
            }
        });
        analytics.page();

        // When Segment is ready, init FB Pixel and Amplitude Session Replay.
        analytics.ready(() => {
            initFbPixel();

            // Init session replay with anonymousId as deviceId (fire-and-forget)
            try {
                var user = analytics.user();
                var anonymousId = user && user.anonymousId && user.anonymousId();
                if (anonymousId && window.initSessionReplay) {
                    window.initSessionReplay(anonymousId);
                }
            } catch (e) {
                // Silently ignore - session replay is non-critical
            }
        });
    }

    if (isProd) {
        initAnalytics("cnb8gKwyLx3YBme9usIPx0VvXHXEhZFI");
        initKakao(
            "2d6260d7ee28cec350ad50a62a726d3e",
            "208597432233381347"
        );
    } else {
        initAnalytics("LPeR1g0jVdAe5FTJZ0cFIVTNZHLpwJoP");
        initKakao(
            "f62e8c33d755ee37e6571d386fc43873",
            "8239936643395699044"
        );
    }
</script>

<script>
  (function () {
    const STATSIG_SIDECAR_URL =
      "https://cdn.jsdelivr.net/npm/statsig-sidecar/dist/index.min.js?apikey=client-y6tBYCaqW1Ny2vkzyP5Y8cr2nhO4HgKk2YFxQ2YC7y8";

    const SIDECAR_MAX_RETRIES = 50; // ~10s with 200ms interval
    const SIDECAR_RETRY_DELAY = 200;

    function loadStatsigSidecarScriptOnce() {
      if (window.__statsigSidecar__ || window.__statsigSidecarLoading) {
        console.log("[Sidecar] Script already loaded or loading, skipping");
        return;
      }

      window.__statsigSidecarLoading = true;

      const script = document.createElement("script");
      script.src = STATSIG_SIDECAR_URL;
      script.async = true;

      script.onload = function () {
        console.log("[Sidecar] Statsig Sidecar script loaded");
      };

      script.onerror = function (err) {
        console.error("[Sidecar] Failed to load Statsig Sidecar script", err);
        window.__statsigSidecarLoading = false;
      };

      document.head.appendChild(script);
    }

    function initStatsigSidecarWithRetry() {
      let attempts = 0;

      function tryInit() {
        const analytics = window.analytics;

        if (!analytics || typeof analytics.user !== "function") {
          attempts++;
          if (attempts > SIDECAR_MAX_RETRIES) {
            console.warn("[Sidecar] analytics/user not available, giving up");
            return;
          }
          return setTimeout(tryInit, SIDECAR_RETRY_DELAY);
        }

        let user;
        try {
          user = analytics.user();
        } catch (e) {
          attempts++;
          console.warn("[Sidecar] Error getting analytics.user()", e);
          if (attempts > SIDECAR_MAX_RETRIES) return;
          return setTimeout(tryInit, SIDECAR_RETRY_DELAY);
        }

        if (!user || typeof user.anonymousId !== "function") {
          attempts++;
          if (attempts > SIDECAR_MAX_RETRIES) {
            console.warn("[Sidecar] user.anonymousId() not available, giving up");
            return;
          }
          return setTimeout(tryInit, SIDECAR_RETRY_DELAY);
        }

        const anonId = user.anonymousId && user.anonymousId();
        if (!anonId) {
          attempts++;
          if (attempts > SIDECAR_MAX_RETRIES) {
            console.warn("[Sidecar] anonymousId is empty, giving up");
            return;
          }
          return setTimeout(tryInit, SIDECAR_RETRY_DELAY);
        }

        console.log("[Sidecar] Analytics ready with anonymousId:", anonId);

        // 1) Set Statsig user
        window.statsigUser = {
          customIDs: {
            stableID: anonId,
          },
        };

        // 2) Load Sidecar
        loadStatsigSidecarScriptOnce();
      }

      tryInit();
    }

    function hookIntoAnalyticsReady() {
      const analytics = window.analytics;

      if (!analytics || typeof analytics.ready !== "function") {
        // Fallback: poll until analytics.ready exists, then hook
        let readyAttempts = 0;
        const maxReadyAttempts = 50;
        const interval = setInterval(() => {
          const a = window.analytics;
          if (a && typeof a.ready === "function") {
            clearInterval(interval);
            console.log("[Sidecar] Hooking into analytics.ready (late)");
            a.ready(function () {
              console.log("[Sidecar] analytics.ready fired");
              initStatsigSidecarWithRetry();
            });
          } else if (++readyAttempts > maxReadyAttempts) {
            clearInterval(interval);
            console.warn("[Sidecar] analytics.ready not found, starting direct retry");
            initStatsigSidecarWithRetry();
          }
        }, 200);
        return;
      }

      // Normal path: analytics.ready is available now
      console.log("[Sidecar] Hooking into analytics.ready");
      analytics.ready(function () {
        console.log("[Sidecar] analytics.ready fired");
        initStatsigSidecarWithRetry();
      });
    }

    // Start the whole flow as soon as possible
    if (document.readyState === "complete" || document.readyState === "interactive") {
      hookIntoAnalyticsReady();
    } else {
      document.addEventListener("DOMContentLoaded", hookIntoAnalyticsReady);
    }
  })();
</script>

